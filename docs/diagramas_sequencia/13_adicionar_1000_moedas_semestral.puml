@startuml
title UC13 - Adicionar 1.000 Moedas Semestralmente

' Ativa as barras/caixas de duração nas lifelines
autoactivate on
skinparam SequenceLifeLineBorderColor #6B7280
skinparam SequenceLifeLineBackgroundColor #F3F4F6
skinparam sequenceActivationBorderColor #111827
skinparam sequenceActivationBackgroundColor #DDEBFF

actor "Tempo (Semestral)" as Tempo
control "Agendador Semestral\nMicronaut" as Scheduler
control "ProfessorRepository" as ProfRepo
database "PostgreSQL" as DB

Tempo -> Scheduler: Dispara rotina semestral
Scheduler -> ProfRepo: findAll()
ProfRepo -> DB: SELECT professores
DB --> ProfRepo: Lista de professores
ProfRepo --> Scheduler: Professores

loop Para cada professor
    Scheduler -> Scheduler: saldoCorrente += 1000
    Scheduler -> ProfRepo: update(professor)
    ProfRepo -> DB: UPDATE professor saldo_corrente
    DB --> ProfRepo: Atualizado
end

Scheduler --> Tempo: Rotina concluída

@enduml
