@startuml
left to right direction
skinparam shadowing false
skinparam monochrome true

' ==========================================
' ENTIDADES (Retângulos)
' ==========================================
rectangle "Instituição de Ensino" as Inst
rectangle "Professor" as Prof
rectangle "Aluno" as Alu
rectangle "Empresa Parceira" as Emp
rectangle "Vantagem" as Vant

' ==========================================
' RELACIONAMENTOS (Losangos)
' ==========================================
diamond "Vincula" as Rel_InstProf
diamond "Matricula" as Rel_InstAlu
diamond "Reconhece\n(Envia Moedas)" as Rel_ProfAlu
diamond "Resgata\n(Gera Cupom)" as Rel_AluVant
diamond "Oferece" as Rel_EmpVant

' ==========================================
' CONEXÕES E CARDINALIDADES
' ==========================================
' 1 Instituição possui N Professores
Inst -- Rel_InstProf : "1"
Rel_InstProf -- Prof : "n"

' 1 Instituição possui N Alunos
Inst -- Rel_InstAlu : "1"
Rel_InstAlu -- Alu : "n"

' N Professores enviam moedas para N Alunos
Prof -- Rel_ProfAlu : "n"
Rel_ProfAlu -- Alu : "n"

' N Alunos resgatam N Vantagens
Alu -- Rel_AluVant : "n"
Rel_AluVant -- Vant : "n"

' 1 Empresa oferece N Vantagens
Emp -- Rel_EmpVant : "1"
Rel_EmpVant -- Vant : "n"

@enduml