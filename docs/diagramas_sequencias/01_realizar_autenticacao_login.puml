@startuml
title UC01 - Realizar Autenticacao (Login)

hide footbox
autoactivate off
skinparam shadowing false
skinparam roundcorner 12
skinparam sequenceArrowColor #374151
skinparam sequenceLifeLineBorderColor #9CA3AF
skinparam sequenceLifeLineBackgroundColor #F9FAFB
skinparam sequenceParticipantBorderColor #374151
skinparam sequenceParticipantBackgroundColor #E8F5FF
skinparam sequenceActorBorderColor #374151
skinparam sequenceActorBackgroundColor #FFFFFF
skinparam sequenceDatabaseBorderColor #374151
skinparam sequenceDatabaseBackgroundColor #F3E8FF
skinparam sequenceBoundaryBorderColor #374151
skinparam sequenceBoundaryBackgroundColor #ECFEFF
skinparam sequenceControlBorderColor #374151
skinparam sequenceControlBackgroundColor #F0F9FF
skinparam sequenceActivationBorderColor #111827
skinparam sequenceActivationBackgroundColor #CFE3FF
skinparam ParticipantPadding 35
skinparam BoxPadding 12
skinparam maxMessageSize 90

actor Usuario as U
boundary "Tela de Login\nNext.js" as Front
control "AuthController\nMicronaut" as Auth
control "UsuarioRepository" as Repo
database "PostgreSQL" as DB

U -> Front: Informa e-mail e senha
activate Front

note right of Front
  Valida campos obrigatorios
  e prepara o payload.
end note

Front -> Auth: POST /auth/login\n{email, senha}
activate Auth

Auth -> Repo: findByEmail(email)
activate Repo

Repo -> DB: SELECT usuario WHERE email = ?
activate DB

DB --> Repo: Dados do usuario
deactivate DB

Repo --> Auth: Usuario encontrado
deactivate Repo

alt Credenciais validas
    note right of Auth
      Identifica o tipo de usuario:
      Aluno, Professor ou Empresa.
    end note

    Auth --> Front: 200 OK\n{id, nome, tipoUsuario}

    note right of Front
      Armazena usuario autenticado
      e define a rota do painel.
    end note

    Front --> U: Redireciona para painel do perfil
else Credenciais invalidas
    Auth --> Front: 401 Unauthorized\n{erro}
    Front --> U: Exibe toast de erro
end

deactivate Auth
deactivate Front

@enduml
