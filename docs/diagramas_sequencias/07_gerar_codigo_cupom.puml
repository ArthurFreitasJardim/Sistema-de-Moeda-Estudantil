@startuml
title UC07 - Gerar Código do Cupom

' Configuração visual melhorada
hide footbox
autoactivate off
skinparam shadowing false
skinparam roundcorner 12
skinparam sequence {
    ArrowColor #374151
    LifeLineBorderColor #9CA3AF
    LifeLineBackgroundColor #F9FAFB
    ParticipantBorderColor #374151
    ParticipantBackgroundColor #E8F5FF
    ActorBorderColor #374151
    ActorBackgroundColor #FFFFFF
    DatabaseBorderColor #374151
    DatabaseBackgroundColor #F3E8FF
    BoxBorderColor #9CA3AF
    BoxBackgroundColor #FAFAFA
    GroupBorderColor #9CA3AF
    GroupBackgroundColor #FFFFFF
    ActivationBorderColor #111827
    ActivationBackgroundColor #CFE3FF
    ParticipantPadding 28
    BoxPadding 10
    MessageAlign center
}
skinparam maxMessageSize 70

control "ResgateVantagemController
Micronaut" as Ctrl
control "CupomService" as Cupom
control "ResgateVantagemRepository" as Repo
database "PostgreSQL" as DB

Ctrl -> Cupom: gerarCodigoCupom(resgate)
activate Cupom
note right of Cupom
  Gera código único para o resgate,
  por exemplo: CUPOM-ALUNO-ID-TIMESTAMP.
end note
Cupom -> Repo: associarCodigoAoResgate(codigo)
activate Repo
Repo -> DB: UPDATE resgate_vantagem SET codigo = ?
activate DB
DB --> Repo: OK
deactivate DB
Repo --> Cupom: Resgate atualizado
deactivate Repo
Cupom --> Ctrl: Código do cupom
deactivate Cupom
@enduml
