@startuml
title UC02 - Cadastrar Aluno

hide footbox
autoactivate off
skinparam shadowing false
skinparam roundcorner 12
skinparam sequenceArrowColor #374151
skinparam sequenceLifeLineBorderColor #9CA3AF
skinparam sequenceLifeLineBackgroundColor #F9FAFB
skinparam sequenceParticipantBorderColor #374151
skinparam sequenceParticipantBackgroundColor #E8F5FF
skinparam sequenceActorBorderColor #374151
skinparam sequenceActorBackgroundColor #FFFFFF
skinparam sequenceDatabaseBorderColor #374151
skinparam sequenceDatabaseBackgroundColor #F3E8FF
skinparam sequenceBoundaryBorderColor #374151
skinparam sequenceBoundaryBackgroundColor #ECFEFF
skinparam sequenceControlBorderColor #374151
skinparam sequenceControlBackgroundColor #F0F9FF
skinparam sequenceActivationBorderColor #111827
skinparam sequenceActivationBackgroundColor #CFE3FF
skinparam ParticipantPadding 35
skinparam BoxPadding 12
skinparam maxMessageSize 90

actor Aluno as A
boundary "Tela de Cadastro\nNext.js" as Front
control "AlunoController\nMicronaut" as Ctrl
control "InstituicaoRepository" as InstRepo
control "AlunoRepository" as AlunoRepo
database "PostgreSQL" as DB

A -> Front: Preenche dados do aluno
activate Front

note right of Front
  Remove mascara de CPF/RG,
  normaliza e-mail e valida campos.
end note

Front -> Ctrl: POST /alunos\nAlunoRequest
activate Ctrl

note right of Ctrl
  Valida obrigatoriedade dos campos
  e prepara a instituicao informada.
end note

Ctrl -> InstRepo: findByNome(instituicaoNome)
activate InstRepo

InstRepo -> DB: SELECT instituicao WHERE nome = ?
activate DB

DB --> InstRepo: Instituicao ou vazio
deactivate DB

InstRepo --> Ctrl: Optional<Instituicao>
deactivate InstRepo

alt Instituicao nao existe
    Ctrl -> InstRepo: save(novaInstituicao)
    activate InstRepo

    InstRepo -> DB: INSERT instituicao
    activate DB

    DB --> InstRepo: Instituicao salva
    deactivate DB

    InstRepo --> Ctrl: Instituicao
    deactivate InstRepo
end

Ctrl -> AlunoRepo: save(aluno)
activate AlunoRepo

AlunoRepo -> DB: INSERT usuario/aluno
activate DB

DB --> AlunoRepo: Aluno salvo
deactivate DB

AlunoRepo --> Ctrl: Aluno
deactivate AlunoRepo

Ctrl --> Front: 201 Created\nAlunoResponse
deactivate Ctrl

Front --> A: Exibe toast de sucesso\ne atualiza lista
deactivate Front

@enduml
